#!/bin/bash
# CLI для управления остатками товаров Ozon

set -e

# Определить директорию скрипта
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(cd "${SCRIPT_DIR}/../lib" && pwd)"

# Загрузить модули
source "${LIB_DIR}/common/logger.sh"
source "${LIB_DIR}/ozon/auth.sh"
source "${LIB_DIR}/common/http.sh"
source "${LIB_DIR}/common/formatter.sh"
source "${LIB_DIR}/ozon/stocks.sh"

# Цвета для вывода
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Показать help
show_help() {
    cat <<EOF
Использование: mp-stocks <команда> [опции]

Команды:
  list                         Показать остатки всех товаров
  list --low                   Показать только товары с низкими остатками (< 10)
  get <sku>                    Показать остаток конкретного товара
  update <sku> <quantity>      Обновить остаток товара

Опции:
  --mock                       Использовать mock данные (для тестирования без API)
  --threshold <num>            Порог низкого остатка (по умолчанию 10)
  --warehouse <id>             ID склада (опционально)
  --limit <num>                Количество товаров (по умолчанию 100)

Примеры:
  mp-stocks list                           # Показать все остатки
  mp-stocks list --low                     # Только товары с низкими остатками
  mp-stocks list --low --threshold 5       # Остатки < 5 шт
  mp-stocks list --mock                    # Тестирование с mock данными
  mp-stocks get TWS-PRO-001                # Остаток конкретного товара
  mp-stocks update TWS-PRO-001 100         # Установить остаток 100 шт

EOF
}

# Команда: list - показать остатки
cmd_list() {
    local args=()
    local show_low=false
    local is_mock=false
    
    # Парсинг аргументов
    while [[ $# -gt 0 ]]; do
        case $1 in
            --mock)
                args+=("--mock")
                is_mock=true
                shift
                ;;
            --low)
                show_low=true
                shift
                ;;
            --threshold|--warehouse|--limit)
                args+=("$1" "$2")
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done
    
    # Загрузить credentials если не mock режим
    if [[ "$is_mock" == "false" ]]; then
        load_credentials
        check_ozon_credentials || exit 1
    fi
    
    echo ""
    echo -e "${BLUE}📦 Остатки товаров${NC}"
    echo ""
    
    # Получить остатки
    local stocks_json
    if [[ "$show_low" == "true" ]]; then
        stocks_json=$(check_low_stocks "${args[@]}")
    else
        stocks_json=$(get_stocks "${args[@]}")
    fi
    
    local result=$?
    
    if [[ $result -ne 0 ]]; then
        echo -e "${RED}ERROR: Не удалось получить остатки${NC}" >&2
        exit 1
    fi
    
    # Форматировать и вывести
    format_stocks "$stocks_json" "$show_low"
    
    echo ""
}

# Команда: get - показать остаток товара
cmd_get() {
    local sku=$1
    shift
    
    if [[ -z "$sku" ]]; then
        echo "ERROR: Укажите SKU товара" >&2
        echo "" >&2
        echo "Использование: mp-stocks get <sku> [--mock]" >&2
        echo "" >&2
        exit 1
    fi
    
    local args=("$sku")
    local is_mock=false
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --mock)
                args+=("--mock")
                is_mock=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
    
    # Загрузить credentials если не mock режим
    if [[ "$is_mock" == "false" ]]; then
        load_credentials
        check_ozon_credentials || exit 1
    fi
    
    echo ""
    echo -e "${BLUE}📦 Остаток товара${NC}"
    echo ""
    
    # Получить остаток
    local stock_data=$(get_stock_by_sku "${args[@]}")
    local result=$?
    
    if [[ $result -ne 0 ]] || [[ -z "$stock_data" ]]; then
        echo "Товар с SKU \"$sku\" не найден"
        exit 1
    fi
    
    # Форматировать вывод
    echo "$stock_data" | jq -r '
"SKU: \(.sku)
Название: \(.name // "не указано")
📦 Остаток: \(.stock) шт
🔒 Зарезервировано: \(.reserved) шт
🏢 Склад: \(.warehouse_name // "не указан")" +
(if .stock < 10 then "\n⚠️  НИЗКИЙ ОСТАТОК!" else "" end)'
    
    echo ""
}

# Команда: update - обновить остаток
cmd_update() {
    local sku=$1
    local new_quantity=$2
    shift 2
    
    if [[ -z "$sku" ]] || [[ -z "$new_quantity" ]]; then
        echo "ERROR: Укажите SKU и новое количество" >&2
        echo "" >&2
        echo "Использование: mp-stocks update <sku> <quantity> [--mock] [--warehouse <id>]" >&2
        echo "" >&2
        exit 1
    fi
    
    local is_mock=false
    local update_args=("$sku" "$new_quantity")
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --mock)
                update_args+=("--mock")
                is_mock=true
                shift
                ;;
            --warehouse)
                update_args+=("--warehouse" "$2")
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done
    
    # Загрузить credentials если не mock режим
    if [[ "$is_mock" == "false" ]]; then
        load_credentials
        check_ozon_credentials || exit 1
    fi
    
    echo ""
    echo -e "${BLUE}📦 Обновление остатка${NC}"
    echo ""
    
    # Получить текущий остаток
    local get_args=("$sku")
    [[ "$is_mock" == "true" ]] && get_args+=("--mock")
    
    local current_stock_data=$(get_stock_by_sku "${get_args[@]}")
    
    if [[ -n "$current_stock_data" ]]; then
        local old_quantity=$(echo "$current_stock_data" | jq -r '.stock')
        local product_name=$(echo "$current_stock_data" | jq -r '.name // "не указано"')
        
        echo "Товар: $product_name"
        echo "SKU: $sku"
        echo ""
        echo "Текущий остаток: $old_quantity шт"
        echo "Новый остаток:   $new_quantity шт"
        echo ""
    else
        echo "SKU: $sku"
        echo "Новый остаток: $new_quantity шт"
        echo ""
        echo -e "${YELLOW}WARNING: Не удалось получить текущий остаток${NC}"
        echo ""
    fi
    
    # Подтверждение
    read -p "Подтвердите обновление остатка (y/N): " confirm
    
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Отменено"
        exit 0
    fi
    
    echo ""
    echo "🔄 Обновление остатка..."
    
    # Выполнить обновление
    local update_json=$(update_stock "${update_args[@]}")
    local result=$?
    
    if [[ $result -ne 0 ]]; then
        echo ""
        echo -e "${RED}ERROR: Не удалось обновить остаток${NC}" >&2
        exit 1
    fi
    
    # Проверить результат
    local updated=$(echo "$update_json" | jq -r '.result[0].updated // false')
    local errors=$(echo "$update_json" | jq -r '.result[0].errors // [] | length')
    
    if [[ "$updated" == "true" ]] && [[ "$errors" == "0" ]]; then
        echo ""
        echo -e "${GREEN}✅ Остаток обновлён успешно!${NC}"
        echo ""
        
        log_info "Stock updated: sku=$sku old=${old_quantity:-unknown} new=$new_quantity"
    else
        echo ""
        echo -e "${RED}❌ Ошибка обновления остатка${NC}"
        echo "$update_json" | jq -r '.result[0].errors[]' 2>/dev/null || echo "Неизвестная ошибка"
        exit 1
    fi
}

# Main
case "${1:-}" in
    list)
        shift
        cmd_list "$@"
        ;;
    get)
        shift
        cmd_get "$@"
        ;;
    update)
        shift
        cmd_update "$@"
        ;;
    -h|--help|help)
        show_help
        ;;
    "")
        echo "ERROR: Команда не указана" >&2
        echo "" >&2
        show_help
        exit 1
        ;;
    *)
        echo "ERROR: Неизвестная команда: $1" >&2
        echo "" >&2
        show_help
        exit 1
        ;;
esac
